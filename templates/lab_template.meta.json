  "schema_examples": {
    "Cover": {
      "Title": "Correctable landmark discovery via large models for vision-language navigation",
      "Title_chinese": "通过大型模型进行可校正的坐标探索，用于视觉语言导航",
      "Reporter": "汇报人：澳门科技大学武小涵       专业：智能技术",
      "Date": "2026.05.19"
    },
    "TOC": {
      "Bullets": "文献介绍\n研究问题（该研究主要聚焦解决了什么问题）\n研究方法\n文献发现&结论\n讨论（不足和未来方向）",
      "Title": "目录"
    },
    "JournalIntro": {
      "Bullets": "期刊：IEEE Transactions on Pattern Analysis and Machine Intelligence\n作者：Bingqian Lin; Yunshuang Nie; Ziming Wei; Yi Zhu; Hang Xu; Shikui Ma等\n单位/研究团队：中山大学（深圳）、华为诺亚方舟实验室",
      "Subtitle": "文献介绍"
    },
    "Background": {
      "Bullets": "本研究将视觉‑语言导航（VLN）重构为“开放世界的顺序地标发现”问题，提出 CONSOLE 框架：先用大语言模型（如 ChatGPT）生成“可导航顺序地标”与“地标共现”先验，再用 CLIP 进行可纠正的地标发现与观测增强，以此抑制大模型知识噪声并提升行动决策的准确性。论文在 R2R、REVERIE、R4R、RxR 四大数据集上系统评估，较强基线（HAMT、DUET）均有稳定增益，并在 R2R 与 R4R 的“unseen”场景上达成新的 SOTA。方法学上，作者以“可纠正性”为关键词：先验由 LLM 给出，但在视觉约束下通过可学习的打分与一致性损失进行动态校正，以避免“懂很多但说不准”的知识误导。该思路一方面强调了跨模态知识的引入，另一方面强调了任务域内视觉反馈的闭环纠偏，这对任何具身智能导航问题都具有普适意义。",
      "Subtitle": "研究背景"
    },
    "Background_WideImage": {
      "Bullets": "LLM/VLM 预训练于超大规模网络语料，蕴含开放世界的共识知识（如地标共现），能为具身导航带来强有力的语义先验；但域间差异导致“直接用”常引入噪声甚至误导。\n研究问题：\n如何激活且可靠地使用大模型中的导航相关知识，同时确保其在实际观测下被动态纠正？目标：在长序列指令与复杂室内环境中，借助“顺序地标 + 共现”先验，对“当前应关注何物、往哪走”进行更稳健的推理，并在多数据集/多基线上验证普适性。",
      "Subtitle": "研究内容"
    },
    "Background_ImageOnly": {
      "Subtitle": "研究内容"
    },
    "Background_TextOnly": {
      "Bullets": "提出了一种名为 \"CONSOLE \"的新型 VLN 范式，以一种可修正的方式激活和利用大型模型中丰富的开放世界知识，从而在减轻大型模型带来的误导的同时有效地帮助 VLN。我们将 VLN 视为一个开放世界的连续地标发现问题，以便有效地从 LLM 和 VLM 中获取对 VLN 有帮助的知识。\n基于观测增强策略，可修正地标发现方案可以与不同的 VLN 模型优雅地结合起来。在 R2R、REVERIE、R4R 和 RxR 等多个流行的 VLN 基准上，CONSOLE 的表现优于强基准。CONSOLE 还在 R2R 和 R4R 上取得了新的 SOTA 结果。",
      "Subtitle": "研究问题"
    },
    "Methods": {
      "Bullets": "方法管线包括四步：\n先验生成——设计多样化任务示例的提示，约束 LLM 输出可导航的顺序地标（避免抽象词、强调短语级地标）与可见的共现物（如“厨房‑灶台‑冰箱”），得到每个地标的共现集合；\n可纠正地标发现——在时间步 t，将指令、观测和共现先验送入“学习式共现打分”模块，以 CLIP 特征度量视觉匹配度，再通过一致性损失用导航监督信号对先验进行重排与抑噪；\n观测增强——用已纠正地标特征增强原始视觉特征，作为 VLN agent 的输入表征\n(D)   训练目标——导航损失（模仿+强化）叠加一致性与对比损失，兼顾行为正确性与先验校正。论文列出关键变量与记号，便于实现复现与跨模型对接。",
      "Subtitle": "研究思路"
    },
    "Methods_WideImage": {
      "Bullets": "学习式共现打分（LS）与行动决策\n引入可学习的共现打分模块：以 CLIP 文本‑图像对齐提取候选地标/共现的视觉可见性与语义相似度，并结合导航监督（通过一致性损失）对“先验权重”进行再排序，使得“更可能在当前视野中出现、且对达成当前子目标更关键”的地标/共现获得更高权重，反之被抑制。",
      "Subtitle": "主要研究方法"
    },
    "Methods_ImageOnly": {
      "Subtitle": "主要研究方法"
    },
    "Methods_TextOnly": {
      "Bullets": "先验质量决定上限。作者通过提示工程与少样例学习，让 LLM 输出可观察、可落地的地标与共现（显式禁止抽象词如“support/right”等），并强调导航顺序而非文本顺序。实验与可视化显示：增加覆盖多样描述的示例（如名词、名词短语）后，LLM 能从“只抽到 table”提升到“抽到 table with China”等更精确地标；为“共现生成”加入可见性约束后，能把噪声词替换为“statue”等更有辨识度的视觉对象，显著提升后续纠正与匹配的上限。此处还比较了 ChatGPT 与 ConceptNet 的“共现可见性”：前者对视觉可见物的可控生成更强。",
      "Subtitle": "主要研究方法"
