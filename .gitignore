# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- venv / uv ---
.venv/
venv/
.uv/

# --- IDE ---
.idea/
.vscode/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- secrets ---
config/secrets.env
config/config.yaml
config/voices.json
.env
.env.*
!.env.example

# --- runtime artifacts (papercast) ---
inbox/*
!inbox/.gitkeep
archive/*
!archive/.gitkeep
work/*
!work/.gitkeep
review/*
!review/.gitkeep
output/*
!output/.gitkeep
logs/*
!logs/.gitkeep

# templates — user-managed PPT masters + parsed schema. Not part of
# the source distribution; each install brings its own. We only track
# the *.example.pptx skeletons so the directory has something to clone
# into and tests/docs have a stable filename to reference.
templates/*
!templates/.gitkeep
!templates/*.example.pptx
!templates/README.md

# --- test ---
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# --- webui ---
webui/node_modules/
webui/dist/
webui/.pnpm-approved-builds
papercast/server/static/
webui/tsconfig.tsbuildinfo
webui/.vite/
webui/logs/

# --- evaluation artifacts ---
# `scripts/eval_figures.py` writes a markdown summary + many PNG crops.
# Commit the .md (small, human-readable diff) but leave the PNGs out
# of git (large, binary, regenerated by the script).
reports/eval_figures/*/
