# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- venv / uv ---
.venv/
venv/
.uv/

# --- IDE ---
.idea/
.vscode/
*.swp

# --- Claude Code 本地配置（个人权限白名单 / 本机路径，不入仓） ---
.claude/

# --- 内部规划/交接文档（含本机路径 + sprint 内部细节，不入仓） ---
docs/PLAN_P*.md
docs/PLAN_WEBUI.md
docs/HANDOFF_*.md
docs/SMOKE_FIX_*.md

# --- OS ---
.DS_Store
Thumbs.db

# --- secrets ---
config/secrets.env
config/config.yaml
config/voices.json
.env
.env.*
!.env.example

# --- runtime artifacts (papercast) ---
inbox/*
!inbox/.gitkeep
archive/*
!archive/.gitkeep
work/*
!work/.gitkeep
review/*
!review/.gitkeep
output/*
!output/.gitkeep
logs/*
!logs/.gitkeep

# templates — user-managed PPT masters + parsed schema. Not part of
# the source distribution; each install brings its own. We only track
# the *.example.pptx skeletons so the directory has something to clone
# into and tests/docs have a stable filename to reference.
templates/*
!templates/.gitkeep
!templates/*.example.pptx
!templates/README.md

# --- test ---
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# --- webui ---
webui/node_modules/
webui/dist/
webui/.pnpm-approved-builds
papercast/server/static/
webui/tsconfig.tsbuildinfo
webui/.vite/
webui/logs/

# --- evaluation artifacts ---
# Local-only smoke + eval scripts and their reports. They reference
# absolute paths or rely on PDFs the maintainer keeps offline; not
# useful for outside contributors and noisy in diffs.
scripts/p1_smoke.py
scripts/eval_figures.py
reports/
